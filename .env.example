# Shared MySQL config for the Python analysis pipeline.
ANTIBOT_DB_HOST=localhost
ANTIBOT_DB_PORT=3306
ANTIBOT_DB_USER=root
ANTIBOT_DB_PASSWORD=CHANGE_ME
ANTIBOT_DB_NAME=anti_bot
ANTIBOT_DB_CHARSET=utf8mb4

# Source table read by pipeline/data_read.py.
# Real source rows contain rest_json plus click_time/url/hash columns.
ANTIBOT_SOURCE_TABLE=fingerprints_sample
ANTIBOT_SOURCE_JSON_FIELD=rest_json

# Batch processing. Use 0 to disable batching; leave ANTIBOT_MAX_ROWS empty for all rows.
ANTIBOT_BATCH_SIZE=10000
ANTIBOT_MAX_ROWS=

# Result tables written by pipeline/save_to_sql.py.
ANTIBOT_RESULT_TABLE=bot_detection_results
ANTIBOT_RULE_HIT_TABLE=bot_rule_hits
